# ───── Salario — Gestión de Clientes (.gitignore) ─────

# OS
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Editores e IDEs
.vscode/
.idea/
*.swp
*.swo
.history/

# Node (por si en algún momento agregamos build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Variables de entorno y secretos
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# Logs y temporales
*.log
*~
*.bak
*.tmp
*.orig

# Sesiones / caches locales que pueda dejar el editor o Claude Cowork
.claude/
.cache/
